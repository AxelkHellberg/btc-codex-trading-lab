  "keywords": [
    "typescript",
    "nodejs",
    "openai",
    "codex",
    "fastify",
    "postgresql",
    "redis",
    "paper-trading",
    "algorithmic-trading",
    "binance"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AxelkHellberg/btc-codex-trading-lab.git"
  },
  "bugs": {
